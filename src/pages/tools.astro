---
import MainGridLayout from "@layouts/MainGridLayout.astro";

const tools = [
	{
		name: "Astro",
		description: "Static site framework used by this blog.",
		url: "https://astro.build/",
	},
	{
		name: "GitHub Pages",
		description: "Static hosting for this site.",
		url: "https://pages.github.com/",
	},
	{
		name: "Pagefind",
		description: "Static search used by this blog.",
		url: "https://pagefind.app/",
	},
];
---

<MainGridLayout title="Tools" description="Useful websites and tools">
	<div class="card-base px-6 py-6 md:px-9 md:py-8">
		<div class="mb-6">
			<h1 class="mb-2 text-3xl font-bold text-black/90 transition dark:text-white/90">Tools</h1>
			<p class="text-50 transition">Useful websites and tools collected for daily work.</p>
		</div>
		<div class="grid gap-3 md:grid-cols-2">
			{tools.map((tool) => (
				<a href={tool.url} target="_blank" rel="noopener noreferrer"
				   class="btn-card block rounded-xl p-4 text-left active:scale-[0.99]">
					<div class="font-bold text-black/80 transition dark:text-white/80">{tool.name}</div>
					<div class="mt-1 text-sm text-50 transition">{tool.description}</div>
				</a>
			))}
		</div>
	</div>
</MainGridLayout>
