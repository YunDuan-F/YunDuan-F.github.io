---
import { getEntry } from "astro:content";
import MainGridLayout from "@layouts/MainGridLayout.astro";
import { parseMarkdownLinkCardPage } from "@utils/markdown-table";

const friendsPage = await getEntry("spec", "friends");

if (!friendsPage) {
	throw new Error("Friends page content not found");
}

const page = parseMarkdownLinkCardPage(
	friendsPage.body,
	"Friends",
	"Friend links",
);
---

<MainGridLayout title={page.title} description={page.description}>
	<div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
		<div class="card-base z-10 px-6 py-6 md:px-9 md:py-8 relative w-full">
			<div class="mb-6">
				<h1 class="mb-2 text-3xl font-bold text-black/90 transition dark:text-white/90">{page.title}</h1>
				<p class="text-50 transition">{page.description}</p>
			</div>
			<div class="grid gap-3 md:grid-cols-2">
				{page.cards.map((friend) => (
					<a href={friend.url} target="_blank" rel="noopener noreferrer"
					   class="btn-card group block rounded-xl p-4 text-left active:scale-[0.99]">
						<div class="font-bold text-black/80 transition group-hover:text-[var(--primary)] dark:text-white/80">{friend.name}</div>
						<div class="mt-1 text-sm text-50 transition">{friend.description}</div>
					</a>
				))}
			</div>
		</div>
	</div>
</MainGridLayout>
