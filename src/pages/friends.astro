---
import MainGridLayout from "@layouts/MainGridLayout.astro";

const friends = [
	{
		name: "Fuwari",
		description: "The Astro theme base used by this blog.",
		url: "https://github.com/saicaca/fuwari",
	},
	{
		name: "Reimu",
		description: "Reference for article reading and code block style.",
		url: "https://github.com/D-Sketon/hexo-theme-reimu",
	},
];
---

<MainGridLayout title="Friends" description="Friend links">
	<div class="card-base px-6 py-6 md:px-9 md:py-8">
		<div class="mb-6">
			<h1 class="mb-2 text-3xl font-bold text-black/90 transition dark:text-white/90">Friends</h1>
			<p class="text-50 transition">Friend links and reference sites.</p>
		</div>
		<div class="grid gap-3 md:grid-cols-2">
			{friends.map((friend) => (
				<a href={friend.url} target="_blank" rel="noopener noreferrer"
				   class="btn-card block rounded-xl p-4 text-left active:scale-[0.99]">
					<div class="font-bold text-black/80 transition dark:text-white/80">{friend.name}</div>
					<div class="mt-1 text-sm text-50 transition">{friend.description}</div>
				</a>
			))}
		</div>
	</div>
</MainGridLayout>
